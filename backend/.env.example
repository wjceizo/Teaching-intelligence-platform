DATABASE_URL=postgresql+asyncpg://app:secret@localhost:5432/mathplatform
REDIS_URL=redis://localhost:6379/0

JWT_SECRET=replace-with-a-random-32-char-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

ANTHROPIC_API_KEY=your-anthropic-key
OPENAI_API_KEY=your-openai-key

MILVUS_HOST=localhost
MILVUS_PORT=19530

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=math-platform

DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000
APP_VERSION=0.1.0
SANDBOX_PYTHON_IMAGE=python:3.12-slim
SANDBOX_JAVASCRIPT_IMAGE=node:22-slim
SANDBOX_CPP_IMAGE=gcc:14
